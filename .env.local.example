# Supabase — get these from your project settings at supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ACLED — register at acleddata.com/account
ACLED_API_KEY=
ACLED_EMAIL=

# ReliefWeb — no key needed, just pick an app name
RELIEFWEB_APP_NAME=educateyourself

# UNHCR — register at data.unhcr.org
UNHCR_API_KEY=

# Sync route — pick any random secret string, used as x-sync-secret header
SYNC_SECRET=

# Session — any long random string (min 32 chars), used to sign JWT cookies
SESSION_SECRET=
